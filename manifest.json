{
  "manifest_version": 3,
  "name": "DeepSeek Bulk Delete",
  "version": "1.0.0",
  "description": "Bulk delete DeepSeek chat conversations",
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    },
    "default_popup": "popup.html",
    "default_title": "DeepSeek Bulk Delete"
  },
  "permissions": ["scripting", "activeTab"],
  "content_scripts": [
    {
      "matches": ["*://chat.deepseek.com/*"],
      "js": [
        "extensionCore.js",
        "config.js",
        "globals.js",
        "utils.js",
        "domHandler.js",
        "conversationHandler.js",
        "checkboxManager.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
